# ─────────────────────────────────────────────────────────────────────────────
# IoT Behavioral Analysis System — Environment configuration
# Copy this file to .env and customize the values before starting.
# ─────────────────────────────────────────────────────────────────────────────

# ── RTSP Stream ───────────────────────────────────────────────────────────────
# IP camera URL. Format: rtsp://user:password@host:port/path
RTSP_URL=rtsp://USER:PASSWORD@IP_CAMERA:554/stream2

# Local alternative (e.g. with mediamtx / ffmpeg):
# RTSP_URL=rtsp://localhost:8554/video

# ── Display window ────────────────────────────────────────────────────────────
WINDOW_NAME=IoT Camera - Phone Detection

# ── Phone Detection model (MediaPipe EfficientDet) ────────────────────────────
# Local path where the model (.tflite) will be saved.
PHONE_MODEL_PATH=efficientdet_lite2.tflite
# URL to download the model if not present.
PHONE_MODEL_URL=https://storage.googleapis.com/mediapipe-models/object_detector/efficientdet_lite2/float32/1/efficientdet_lite2.tflite

# Initial confidence threshold for the phone detector (0.01 – 0.95).
PHONE_CONF_THRESHOLD=0.35

# ── Attention Detection model (YOLOv8 Pose + MediaPipe Face Landmarker) ───────
# Path and URL for the YOLOv8n-pose model.
YOLO_MODEL_PATH=yolov8n-pose.pt
YOLO_MODEL_URL=https://github.com/ultralytics/assets/releases/download/v8.4.0/yolov8n-pose.pt

# Initial confidence threshold for YOLO (0.01 – 0.95).
YOLO_CONF_THRESHOLD=0.35

# Path and URL for the MediaPipe Face Landmarker model.
FACE_LANDMARKER_PATH=face_landmarker.task
FACE_LANDMARKER_URL=https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task

# ── Head angle thresholds (degrees) ──────────────────────────────────────────
# Pitch below which the head is considered "down" (lecture mode).
DOWN_THRESHOLD=-18.0
# Pitch above which the head is considered "up" (exercise mode).
UP_THRESHOLD=12.0

# ── Minimum interval between two inferences (seconds) ────────────────────────
MIN_PROCESS_INTERVAL=0.12
